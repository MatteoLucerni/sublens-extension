{
  "manifest_version": 3,
  "name": "Subtitle Lens",
  "description": "Blur subtitles until you want to see them, then click, Ctrl+click or drag-select any word for instant translation and dictionary definitions. Currently supports Netflix.",
  "version": "0.4.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Subtitle Lens settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["settings.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["scripting", "storage"],
  "host_permissions": ["https://translate.googleapis.com/*", "https://www.netflix.com/*"]
}
